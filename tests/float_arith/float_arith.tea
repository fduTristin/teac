use std;

fn matmul(
    a0: &[f32], a1: &[f32], a2: &[f32],
    b0: &[f32], b1: &[f32], b2: &[f32],
    c0: &[f32], c1: &[f32], c2: &[f32]
) {
    c0[0] = a0[0]*b0[0] + a0[1]*b1[0] + a0[2]*b2[0];
    c0[1] = a0[0]*b0[1] + a0[1]*b1[1] + a0[2]*b2[1];
    c0[2] = a0[0]*b0[2] + a0[1]*b1[2] + a0[2]*b2[2];

    c1[0] = a1[0]*b0[0] + a1[1]*b1[0] + a1[2]*b2[0];
    c1[1] = a1[0]*b0[1] + a1[1]*b1[1] + a1[2]*b2[1];
    c1[2] = a1[0]*b0[2] + a1[1]*b1[2] + a1[2]*b2[2];

    c2[0] = a2[0]*b0[0] + a2[1]*b1[0] + a2[2]*b2[0];
    c2[1] = a2[0]*b0[1] + a2[1]*b1[1] + a2[2]*b2[1];
    c2[2] = a2[0]*b0[2] + a2[1]*b1[2] + a2[2]*b2[2];
}

fn print_row(r: &[f32]) {
    let i:i32 = 0;
    while i < 3 {
        let v:i32 = r[i] as i32;
        std::putint(v);
        std::putch(32);
        i = i + 1;
    }
    std::putch(10);
}

fn main() -> i32 {
    // A = [[1.73, 0.41, 3.62],
    //      [2.09, 4.85, 0.17],
    //      [0.56, 3.24, 2.91]]
    let a0: [f32; 3];
    let a1: [f32; 3];
    let a2: [f32; 3];
    a0[0] = 1.73; a0[1] = 0.41; a0[2] = 3.62;
    a1[0] = 2.09; a1[1] = 4.85; a1[2] = 0.17;
    a2[0] = 0.56; a2[1] = 3.24; a2[2] = 2.91;

    // B = [[0.83, 2.47, 1.36],
    //      [3.15, 0.62, 4.08],
    //      [1.74, 3.59, 0.25]]
    let b0: [f32; 3];
    let b1: [f32; 3];
    let b2: [f32; 3];
    b0[0] = 0.83; b0[1] = 2.47; b0[2] = 1.36;
    b1[0] = 3.15; b1[1] = 0.62; b1[2] = 4.08;
    b2[0] = 1.74; b2[1] = 3.59; b2[2] = 0.25;

    let c0: [f32; 3];
    let c1: [f32; 3];
    let c2: [f32; 3];

    matmul(&a0, &a1, &a2, &b0, &b1, &b2, &c0, &c1, &c2);

    print_row(&c0);
    print_row(&c1);
    print_row(&c2);

    return 0;
}
